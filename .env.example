# Database
DATABASE_ENABLED=true
DATABASE_HOST=info_sqlserver
DATABASE_PORT=1433
DATABASE_USER=SA
DATABASE_PASSWORD=YourStrong@Password
DATABASE_NAME=gestao_frotas_api
DATABASE_ENCRYPT=false
DATABASE_TRUST_SERVER_CERTIFICATE=true
DATABASE_AUTO_CREATE=true
DATABASE_CONNECT_RETRIES=10
DATABASE_CONNECT_RETRY_DELAY_MS=3000
TYPEORM_MIGRATIONS_RUN=true

# JWT (minimo 16 caracteres)
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1h
DEFAULT_USER_PASSWORD=aivacol

# Redis
REDIS_ENABLED=true
REDIS_HOST=info_redis
REDIS_PORT=6379
REDIS_TTL=3600
USE_MEMORY_CACHE=false
DEFAULT_CREATED_BY=aivacol

# Auditoria (MongoDB)
# Use mongodb://info_mongodb:27017/audit_db quando a API roda via Docker Compose.
# Use mongodb://localhost:27017/audit_db apenas quando a API roda fora do container.
MONGODB_URI=mongodb://info_mongodb:27017/audit_db
AUDIT_ENABLED=true

# Application
APP_PORT=3001
NODE_ENV=development
