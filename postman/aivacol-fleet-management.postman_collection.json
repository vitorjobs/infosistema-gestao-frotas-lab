    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Login - usuario padrao aivacol",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Autentica o usuario seed e retorna JWT. Status esperado: 200.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickname\": \"aivacol\",\n  \"password\": \"aivacol\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login retorna 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Resposta possui JWT e usuario', function () {",
                  "  pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.token_type).to.eql('Bearer');",
                  "  pm.expect(json.user.nickname).to.eql('aivacol');",
                  "  pm.expect(json.user.email).to.eql('aivacol@example.com');",
                  "  pm.expect(json.user.name).to.eql('Aivacol Admin');",
                  "});",
                  "pm.collectionVariables.set('accessToken', json.access_token);",
                  "pm.collectionVariables.set('userId', String(json.user.sub));"
                ]
              }
            }
          ]
        },
        {
          "name": "Me - token salvo",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me",
            "description": "Retorna dados do JWT validado. Requer Bearer token.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Me retorna usuario autenticado', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.nickname).to.eql('aivacol');",
                  "  pm.expect(json).to.have.property('sub');",
                  "  pm.expect(json.email).to.eql('aivacol@example.com');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Me - sem token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me",
            "description": "Valida protecao JWT global."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Me sem token retorna 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Erro segue envelope global', function () {",
                  "  pm.expect(json.success).to.eql(false);",
                  "  pm.expect(json).to.have.property('statusCode');",
                  "  pm.expect(json).to.have.property('timestamp');",
                  "  pm.expect(json).to.have.property('path');",
                  "  pm.expect(json).to.have.property('method');",
                  "  pm.expect(json.error).to.have.property('code');",
                  "  pm.expect(json.error).to.have.property('message');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
