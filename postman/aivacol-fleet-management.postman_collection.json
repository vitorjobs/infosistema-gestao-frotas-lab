              "raw": "{\n  \"license_plate\": \"{{vehiclePlate}}\",\n  \"chassis\": \"{{vehicleChassis}}\",\n  \"renavam\": \"{{vehicleRenavam}}\",\n  \"year\": 2025,\n  \"model_id\": {{modelId}}\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const now = Date.now();",
                  "const suffix = String(now).slice(-6);",
                  "pm.collectionVariables.set('vehiclePlate', `PM${suffix}`);",
                  "pm.collectionVariables.set('vehicleChassis', `CHS${now}`);",
                  "pm.collectionVariables.set('vehicleRenavam', `REN${now}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Vehicle criado', function () {",
