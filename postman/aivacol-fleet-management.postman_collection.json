        {
          "name": "Health publico - SQL Server e Redis",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health",
            "description": "Verifica SQL Server (`database`) e Redis (`redis`). Retorna 200 quando saudavel ou 503 quando alguma dependencia falhar. Nao exige JWT."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health retorna 200 ou 503', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 503]);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Health inclui database e redis', function () {",
                  "  pm.expect(json).to.have.property('details');",
                  "  pm.expect(json.details).to.have.property('database');",
                  "  pm.expect(json.details).to.have.property('redis');",
                  "});"
