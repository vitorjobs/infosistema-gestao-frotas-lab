                  "  pm.expect(json.license_plate).to.eql(pm.collectionVariables.get('vehiclePlate').toUpperCase());",
                  "  pm.expect(json.chassis).to.eql(pm.collectionVariables.get('vehicleChassis').toUpperCase());",
                  "  pm.expect(String(json.model_id)).to.eql(pm.collectionVariables.get('modelId'));",
