          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lista users paginada', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json).to.have.property('meta');",
                  "  pm.expect(json.data).to.be.an('array');",
                  "  pm.expect(json.meta).to.include.keys('total', 'page', 'limit', 'totalPages');",
                  "  pm.expect(json.meta.page).to.eql(1);",
                  "  pm.expect(json.meta.limit).to.eql(20);",
                  "});",
                  "const user = pm.response.json().data.find((item) => String(item.id) === pm.collectionVariables.get('userId'));",
                  "pm.test('Usuario seed presente e sem senha', function () {",
                  "  pm.expect(user).to.be.an('object');",
                  "  pm.expect(user).to.not.have.property('password_hash');",
