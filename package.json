{
  "name": "gestao_frotas_api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/main",
    "start:prod": "NODE_ENV=production node dist/main",
    "start:dev": "USE_MEMORY_CACHE=true ts-node-dev --respawn --transpile-only src/main.ts",
    "start:dev:redis": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "doctor:drivers": "node -e \"require('mssql'); console.log('driver mssql ok')\"",
    "test": "jest --selectProjects unit",
    "test:e2e": "jest --selectProjects e2e --runInBand",
    "test:cov": "jest --selectProjects unit --coverage",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "seed": "ts-node --transpile-only src/database/seed.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.26",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.1",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.3.2",
    "mongodb": "^6.17.0",
    "mssql": "^12.5.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prom-client": "^14.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.0.0",
    "swagger-ui-express": "^4.6.2",
    "typeorm": "^0.3.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.26",
    "@types/express": "^4.17.13",
    "@types/jest": "^29.5.3",
    "@types/mssql": "^12.3.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "jest": "^29.0.0",
    "sql.js": "^1.13.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
