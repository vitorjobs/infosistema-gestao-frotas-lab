    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Proporção de leituras atendidas pelo cache Redis. Valores baixos podem indicar cache frio, TTL curto ou invalidação excessiva.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 10
      },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "(sum(rate(redis_keyspace_hits_total{job=\"redis\"}[5m])) / clamp_min(sum(rate(redis_keyspace_hits_total{job=\"redis\"}[5m])) + sum(rate(redis_keyspace_misses_total{job=\"redis\"}[5m])), 0.001)) OR on() vector(0)",
          "legendFormat": "Redis hit ratio",
          "refId": "A"
        }
      ],
      "title": "Redis hit ratio",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Evolução das operações de cache hit e miss no Redis para avaliar efetividade do cache da aplicação.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 10,
        "x": 4,
        "y": 10
      },
      "id": 6,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{job=\"redis\"}[5m]) OR on() vector(0)",
          "legendFormat": "hits",
          "refId": "A"
        },
        {
          "expr": "rate(redis_keyspace_misses_total{job=\"redis\"}[5m]) OR on() vector(0)",
          "legendFormat": "misses",
          "refId": "B"
        }
      ],
      "title": "Redis hits e misses",
      "type": "timeseries"
    },
